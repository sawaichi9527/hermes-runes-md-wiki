{
  "schema_version": "m78-first-manual-apply-commit-gate-v1",
  "milestone": "M78 First Manual Apply Commit Gate",
  "mode": "first-manual-apply-commit-gate",
  "scale": "personal-local",
  "write": false,
  "authoritative": false,
  "runtime_dependency_required": false,
  "principle": "commit-gate-validates-final-human-checkpoints-before-any-future-manual-write",
  "gate_mode": "final-pre-write-gate-only",
  "required_semantics": {
    "gate_is_not_commit_executor": true,
    "explicit_human_confirmation_required": true,
    "single_candidate_required": true,
    "single_operation_required": true,
    "single_target_path_required": true,
    "diff_preview_review_required": true,
    "rollback_note_review_required": true,
    "source_reference_review_required": true,
    "pre_apply_smokes_must_pass": true,
    "post_apply_smokes_must_be_defined": true,
    "real_commit_performed": false,
    "real_write_performed": false,
    "automatic_commit_allowed": false,
    "automatic_apply_allowed": false,
    "batch_operation_allowed": false,
    "runtime_authority_escalation_allowed": false
  },
  "required_commit_gate_fields": [
    "candidate_id",
    "operation_id",
    "target_path",
    "source_reference",
    "diff_preview",
    "rollback_note",
    "human_confirmation",
    "pre_apply_smokes",
    "post_apply_smokes"
  ],
  "gate_review_sequence": [
    "review_candidate",
    "review_source_reference",
    "review_target_path",
    "review_diff_preview",
    "review_rollback_note",
    "verify_pre_apply_smokes",
    "confirm_manual_human_decision",
    "prepare_future_commit_boundary"
  ],
  "forbidden_infrastructure": [
    "automatic-commit-worker",
    "automatic-apply-worker",
    "batch-apply-engine",
    "background-write-worker",
    "trusted-write-daemon",
    "runtime-policy-engine",
    "enterprise-workflow-engine",
    "multi-agent-apply-orchestrator"
  ]
}
