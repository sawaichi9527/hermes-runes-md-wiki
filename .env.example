# =========================================================
# Hermes Runes MD Wiki - Environment Example
# Copy this file to .env and fill local values.
# Never commit real .env files.
# =========================================================

# Repository root override
# Default fallback is: ~/workspace/hermes-memory
HERMES_MEMORY_ROOT=~/workspace/hermes-memory

# PostgreSQL connection
# Replace password with your local secret in .env
HERMES_MEMORY_DATABASE_URL=postgresql://hermes_memory_user:replace-with-local-password@127.0.0.1:5432/hermes_memory

# OpenAI-compatible local LLM endpoint
OPENAI_BASE_URL=http://127.0.0.1:1234/v1
OPENAI_MODEL=replace-with-local-model-name
OPENAI_API_KEY=replace-with-local-secret-or-not-needed

# Optional generation defaults
HERMES_DEFAULT_PROJECT=k6-freelancer
HERMES_DEFAULT_SCHEMA=public

# Observation logs
# Default path is under: $HERMES_MEMORY_ROOT/logs/observations
HERMES_OBSERVATION_LOGGING=1
