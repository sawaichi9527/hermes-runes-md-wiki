# =========================================================
# Hermes Runes MD Wiki - Importer Runtime Environment Example
# =========================================================
# Copy this file to tools/importer/.env and fill local values.
#
#   cp tools/importer/.env.example tools/importer/.env
#   vi tools/importer/.env
#
# Never commit real .env files.
# Real secrets, API keys, database passwords, and private endpoint details
# must remain local-only.
# =========================================================

# Repository root override.
# Recommended developer checkout path: ~/workspace/hermes-runes-md-wiki
# Recommended trial checkout path:     ~/workspace-trial/hermes-runes-md-wiki
# The variable name remains HERMES_MEMORY_ROOT for compatibility with existing tools.
HERMES_MEMORY_ROOT=~/workspace/hermes-runes-md-wiki

# PostgreSQL connection.
# Replace all placeholder values in your local tools/importer/.env file.
HERMES_MEMORY_DATABASE_URL=postgresql://DB_USER:DB_PASSWORD@DB_HOST:DB_PORT/DB_NAME

# ---------------------------------------------------------
# M93 minimal beta model env
# ---------------------------------------------------------
# OpenAI-compatible local model endpoint.
# Examples:
#   LM Studio:              http://127.0.0.1:1234/v1
#   llama.cpp server proxy: http://127.0.0.1:8081/v1
OPENAI_BASE_URL=http://127.0.0.1:1234/v1

# Model id exposed by the local OpenAI-compatible endpoint.
# Use the exact model id returned by the endpoint /v1/models list.
OPENAI_MODEL=your-local-model-name

# Local endpoints commonly do not require a real key.
# Keep this as a placeholder unless your endpoint requires authentication.
OPENAI_API_KEY=not-needed

# Optional generation defaults.
HERMES_DEFAULT_PROJECT=sample-project
HERMES_DEFAULT_SCHEMA=public

# Trial-run workspace defaults.
# Override these locally for clean beta-prep trial verification.
HERMES_WORKSPACE_SLUG=freelancer
HERMES_PROJECT=freelancer

# Observation logs.
# Default path is under: $HERMES_MEMORY_ROOT/logs/observations
HERMES_OBSERVATION_LOGGING=1
