# =========================================================
# Hermes Runes MD Wiki - Importer Runtime Environment Example
# Copy this file to tools/importer/.env and fill local values.
# Never commit real .env files.
# =========================================================

# Repository root override
# Recommended default clone path: ~/workspace/hermes-runes-md-wiki
# The variable name remains HERMES_MEMORY_ROOT for compatibility with existing tools.
HERMES_MEMORY_ROOT=~/workspace/hermes-runes-md-wiki

# PostgreSQL connection
# Replace all placeholder values in your local tools/importer/.env file.
HERMES_MEMORY_DATABASE_URL=postgresql://DB_USER:DB_PASSWORD@DB_HOST:DB_PORT/DB_NAME

# OpenAI-compatible local LLM endpoint
OPENAI_BASE_URL=http://127.0.0.1:1234/v1
OPENAI_MODEL=your-local-model-name
OPENAI_API_KEY=not-set

# Optional generation defaults
HERMES_DEFAULT_PROJECT=sample-project
HERMES_DEFAULT_SCHEMA=public

# Observation logs
# Default path is under: $HERMES_MEMORY_ROOT/logs/observations
HERMES_OBSERVATION_LOGGING=1
