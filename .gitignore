# =========================================================
# Hermes Runes MD Wiki - Git Ignore Baseline
# =========================================================

# ---------------------------------------------------------
# Python
# ---------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd

.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------
.venv/
venv/

# ---------------------------------------------------------
# Secrets / credentials
# ---------------------------------------------------------
.env
.env.local
*.secret
*.key
*.pem

# ---------------------------------------------------------
# Logs
# ---------------------------------------------------------
logs/
*.log
*.jsonl

# ---------------------------------------------------------
# Runtime artifacts
# ---------------------------------------------------------
tmp/
*.tmp
*.out

# ---------------------------------------------------------
# Database / vector storage
# ---------------------------------------------------------
postgres-data/
pgdata/
*.sqlite
*.db

# ---------------------------------------------------------
# Local backups
# ---------------------------------------------------------
backups/
*.bak
*.backup

# ---------------------------------------------------------
# IDE / editor
# ---------------------------------------------------------
.vscode/
.idea/

# ---------------------------------------------------------
# OS metadata
# ---------------------------------------------------------
.DS_Store
Thumbs.db

# ---------------------------------------------------------
# Docker runtime leftovers
# ---------------------------------------------------------
*.pid
*.sock

# ---------------------------------------------------------
# Local override configs
# ---------------------------------------------------------
config.local.*
docker-compose.override.yml


# ---------------------------------------------------------
# Local imports / observation artifacts
# ---------------------------------------------------------
imports/
observations/
exports/

# Legacy backup snapshots
archive/legacy-baks/

# Local runtime operation artifacts
var/locks/
var/operations/

# Local operational evidence store
# Generated runes operation logs are local-only and should not be committed.
operations/

# Local Ragnarok observation bundles
bundles/ragnarok-observation/
