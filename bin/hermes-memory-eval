#!/usr/bin/env bash
set -euo pipefail

PYTHON="${PYTHON:-python3}"
ROOT="${HERMES_MEMORY_ROOT:-$HOME/workspace/hermes-memory}"
IMPORTER_DIR="$ROOT/tools/importer"

cd "$IMPORTER_DIR"

if [ -d ".venv" ]; then
  # shellcheck disable=SC1091
  source ".venv/bin/activate"
fi

"$PYTHON" smoke/eval_all.py
