#!/usr/bin/env bash
set -euo pipefail

PYTHON="${PYTHON:-python3}"
ROOT="${HERMES_MEMORY_ROOT:-$HOME/workspace/hermes-runes-md-wiki}"
IMPORTER_DIR="$ROOT/tools/importer"
WORKSPACE_SLUG="${HERMES_WORKSPACE_SLUG:-${HERMES_PROJECT:-k6-freelancer}}"
WIKI_DIR="$ROOT/wiki/$WORKSPACE_SLUG"

echo "== Hermes Memory Check =="

echo "[1/8] root"
test -d "$ROOT"
echo "PASS root=$ROOT"

echo "[2/8] importer"
test -d "$IMPORTER_DIR"
echo "PASS importer=$IMPORTER_DIR"

echo "[3/8] venv"
test -d "$IMPORTER_DIR/.venv"
echo "PASS venv=$IMPORTER_DIR/.venv"

echo "[4/8] env"
test -f "$IMPORTER_DIR/.env"
echo "PASS env=$IMPORTER_DIR/.env"

echo "[5/8] wiki"
test -d "$WIKI_DIR"
echo "PASS wiki=$WIKI_DIR"

echo "[6/8] required scripts"
for required_file in \
  "$IMPORTER_DIR/importer.py" \
  "$IMPORTER_DIR/delete_source.py" \
  "$IMPORTER_DIR/smoke/eval_all.py" \
  "$IMPORTER_DIR/smoke/eval_smoke_m5_2.py" \
  "$IMPORTER_DIR/smoke/eval_smoke_m6_6.py" \
  "$IMPORTER_DIR/smoke/eval_smoke_core_fts.py" \
  "$IMPORTER_DIR/smoke/eval_smoke_m10_observation.py" \
  "$IMPORTER_DIR/smoke/eval_smoke_m11_observation_summary.py" \
  "$IMPORTER_DIR/smoke/eval_smoke_m11_6_sample_project.py"
do
  if [ -f "$required_file" ]; then
    echo "PASS required_file=$required_file"
  else
    echo "MISSING required_file=$required_file" >&2
    exit 1
  fi
done
echo "PASS scripts"

echo "[7/8] commands"
for required_command in \
  hermes-memory-sync \
  hermes-memory-check \
  hermes-memory-eval \
  hermes-memory-restore \
  hermes-memory-import
do
  if command -v "$required_command" >/dev/null 2>&1; then
    echo "PASS command=$required_command"
  elif [ -x "$ROOT/bin/$required_command" ]; then
    echo "PASS repo_command=$ROOT/bin/$required_command"
  else
    echo "MISSING command=$required_command" >&2
    exit 1
  fi
done
echo "PASS commands"

echo "[8/8] database/schema probe"
cd "$IMPORTER_DIR"

if [ -d ".venv" ]; then
  # shellcheck disable=SC1091
  source ".venv/bin/activate"
fi

"$PYTHON" delete_source.py \
  --project "$WORKSPACE_SLUG" \
  --path __hermes_memory_check_probe_not_exist__.md \
  --json >/tmp/hermes-memory-check-delete-probe.json

grep -q '"status": "not_found"' /tmp/hermes-memory-check-delete-probe.json
grep -q '"documents_path": "source_path"' /tmp/hermes-memory-check-delete-probe.json
grep -q '"chunks_document_fk": "document_id"' /tmp/hermes-memory-check-delete-probe.json
echo "PASS database/schema probe"

echo "status=PASS"
