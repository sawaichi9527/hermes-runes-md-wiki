#!/usr/bin/env python3
import argparse
import os
import subprocess
import sys
from pathlib import Path


def repo_root() -> Path:
    env_root = os.environ.get("HERMES_MEMORY_ROOT")
    if env_root:
        return Path(env_root).expanduser().resolve()
    return Path(__file__).resolve().parents[1]


def main() -> int:
    parser = argparse.ArgumentParser(prog="hermes-recall")
    parser.add_argument("query", nargs="*")
    parser.add_argument("--project", default="k6-freelancer")
    parser.add_argument("--schema", default="public")
    parser.add_argument("--mode", choices=["hybrid", "vector", "fts"], default="hybrid")
    parser.add_argument("--diagnose", action="store_true")
    parser.add_argument("--diagnose-context", action="store_true")
    parser.add_argument("--embed-missing", action="store_true")
    parser.add_argument("--dry-run", action="store_true")
    parser.add_argument("--limit", default="5")
    parser.add_argument("--candidate-limit", default="20")
    parser.add_argument("--batch-size", default="16")
    parser.add_argument("--max-content-length", default="800")
    parser.add_argument("--max-chars", default="8000")
    parser.add_argument("--per-chunk-chars", default="2500")
    parser.add_argument("--max-source-chunks", default="2")
    parser.add_argument("--min-rerank-score", default="1.0")
    parser.add_argument("--path", dest="path_filter", default=None)
    parser.add_argument("--heading", dest="heading_filter", default=None)
    parser.add_argument("--no-merge-adjacent-chunks", dest="merge_adjacent_chunks", action="store_false")
    parser.set_defaults(merge_adjacent_chunks=True)
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--no-warn-hf", action="store_true")
    args = parser.parse_args()

    active_modes = sum(
        [
            bool(args.diagnose),
            bool(args.diagnose_context),
            bool(args.embed_missing),
        ]
    )

    if active_modes > 1:
        parser.error(
            "--diagnose, --diagnose-context, and --embed-missing are mutually exclusive"
        )

    root = repo_root()

    if args.diagnose:
        script = root / "tools/importer/retrieval_diagnostics.py"

        cmd = [
            sys.executable,
            str(script),
            "--project", args.project,
            "--schema", args.schema,
            "--limit", str(args.candidate_limit),
        ]

        if args.path_filter:
            cmd.extend(["--path", args.path_filter])

        if args.json:
            cmd.append("--json")

    elif args.diagnose_context:
        if not args.query:
            parser.error("query is required for --diagnose-context")

        script = root / "tools/importer/context_diagnostics.py"

        cmd = [
            sys.executable,
            str(script),
            " ".join(args.query),
            "--project", args.project,
            "--schema", args.schema,
            "--limit", str(args.limit),
            "--candidates", str(args.candidate_limit),
            "--max-chars", str(args.max_chars),
            "--per-chunk-chars", str(args.per_chunk_chars),
            "--max-source-chunks", str(args.max_source_chunks),
            "--min-rerank-score", str(args.min_rerank_score),
        ]

        if args.path_filter:
            cmd.extend(["--path", args.path_filter])

        if args.heading_filter:
            cmd.extend(["--heading", args.heading_filter])

        if not args.merge_adjacent_chunks:
            cmd.append("--no-merge-adjacent-chunks")

        if args.json:
            cmd.append("--json")

    elif args.embed_missing:
        script = root / "tools/importer/embed_missing.py"

        cmd = [
            sys.executable,
            str(script),
            "--project", args.project,
            "--schema", args.schema,
            "--limit", str(args.candidate_limit),
            "--batch-size", str(args.batch_size),
        ]

        if args.path_filter:
            cmd.extend(["--path", args.path_filter])

        if args.dry_run:
            cmd.append("--dry-run")

        if args.json:
            cmd.append("--json")

    else:
        if not args.query:
            parser.error(
                "query is required unless a diagnostics or embedding mode is used"
            )

        script_map = {
            "hybrid": root / "tools/importer/hermes-memory-hybrid-search",
            "vector": root / "tools/importer/hermes-memory-vector-search",
            "fts": root / "tools/importer/hermes-memory-fts-search",
        }

        cmd = [
            str(script_map[args.mode]),
            " ".join(args.query),
            "--project", args.project,
            "--schema", args.schema,
            "--limit", str(args.limit),
            "--max-content-length", str(args.max_content_length),
        ]

        if args.mode == "hybrid":
            cmd.extend(["--candidate-limit", str(args.candidate_limit)])
            if args.heading_filter:
                cmd.extend(["--heading", args.heading_filter])

        if args.path_filter:
            cmd.extend(["--path", args.path_filter])

        if args.json:
            cmd.append("--json")

    env = os.environ.copy()
    if args.no_warn_hf:
        env["HF_HUB_DISABLE_IMPLICIT_TOKEN"] = "1"
        env["TOKENIZERS_PARALLELISM"] = "false"

    return subprocess.call(cmd, env=env)


if __name__ == "__main__":
    raise SystemExit(main())
