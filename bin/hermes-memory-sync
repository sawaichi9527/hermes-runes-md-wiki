#!/usr/bin/env bash
set -euo pipefail

PYTHON="${PYTHON:-python3}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="${HERMES_RUNES_MD_WIKI_ROOT:-${HERMES_MEMORY_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}}"
IMPORTER_DIR="$ROOT/tools/importer"
RUN_SMOKE=0
RUN_SECURE=0

usage() {
  cat <<'EOF'
hermes-memory-sync

Sync Markdown wiki content into the local Hermes Runes PostgreSQL index.

Usage:
  hermes-memory-sync
  hermes-memory-sync --smoke
  hermes-memory-sync --secure
  hermes-memory-sync --secure --smoke
  hermes-memory-sync --help

Options:
  --secure  Run security scan before importer and block sync if findings exist.
  --smoke   Run hermes-memory-smoke after importer completes.
  --help    Show this help message.

Environment:
  PYTHON                    Python executable, default: python3
  HERMES_RUNES_MD_WIKI_ROOT Repo root override for hermes-runes-md-wiki
  HERMES_MEMORY_ROOT        Legacy repo root override, still accepted

Notes:
  - Default behavior only runs importer.py.
  - --secure protects long-term memory from importing real secrets.
  - --smoke validates core recall behavior after sync.
EOF
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --secure)
      RUN_SECURE=1
      shift
      ;;
    --smoke)
      RUN_SMOKE=1
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      echo "ERROR: unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

if [ ! -d "$ROOT" ]; then
  echo "ERROR: repo root not found: $ROOT" >&2
  exit 1
fi

if [ ! -d "$IMPORTER_DIR" ]; then
  echo "ERROR: importer directory not found: $IMPORTER_DIR" >&2
  exit 1
fi

cd "$IMPORTER_DIR"

if [ -d ".venv" ]; then
  # shellcheck disable=SC1091
  source ".venv/bin/activate"
fi

if [ "$RUN_SECURE" -eq 1 ]; then
  echo "[hermes-memory-sync] running security scan..."
  "$PYTHON" security_scan.py --fail-on-findings
fi

echo "[hermes-memory-sync] running importer..."
"$PYTHON" importer.py

if [ "$RUN_SMOKE" -eq 1 ]; then
  echo "[hermes-memory-sync] running smoke test..."
  "$ROOT/bin/hermes-memory-smoke"
fi

echo "[hermes-memory-sync] done"
