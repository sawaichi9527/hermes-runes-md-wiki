#!/usr/bin/env bash
set -euo pipefail

PYTHON="${PYTHON:-python3}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="${HERMES_MEMORY_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}"
IMPORTER_DIR="$ROOT/tools/importer"

# Load local runtime defaults when present so fresh-install smoke follows
# tools/importer/.env instead of falling back to sample-project fixtures.
if [ -f "$IMPORTER_DIR/.env" ]; then
  set -a
  # shellcheck disable=SC1091
  . "$IMPORTER_DIR/.env"
  set +a
fi

cd "$IMPORTER_DIR"

if [ -d ".venv" ]; then
  # shellcheck disable=SC1091
  source ".venv/bin/activate"
fi

"$PYTHON" smoke/eval_smoke_core_fts.py
"$PYTHON" smoke/eval_smoke_plur_bridge.py

if "$PYTHON" -c "import sentence_transformers" >/dev/null 2>&1; then
  echo "Embedding profile detected: running full smoke suite"
  "$PYTHON" smoke/eval_smoke_m5_2.py
  "$PYTHON" smoke/eval_smoke_m10_observation.py
  "$PYTHON" smoke/eval_smoke_m11_observation_summary.py
  "$PYTHON" smoke/eval_smoke_m11_6_sample_project.py
  "$PYTHON" promotion_governance_smoke.py
else
  echo "Embedding profile not installed: skipping hybrid and answer-generation smoke suites"
  echo "Install requirements-embedding.txt to run the full smoke suite"
fi
